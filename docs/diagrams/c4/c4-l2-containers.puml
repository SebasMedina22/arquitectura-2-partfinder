@startuml partfinder-c4-l2-containers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title PartFinder — C4 Nivel 2 (Contenedores)

Person(mechanic, "Mecanico", "Cliente del marketplace.")
Person(supplier, "Proveedor", "Consulta tendencias.")

System_Boundary(partfinder, "PartFinder") {

    Container(ui_gateway, "UI + API Gateway (Nginx)", "Nginx 1.27 + React 18 + Vite", "Sirve la SPA y proxea /api/aggregator, /api/inventory, /api/trends. Puerto 8080.")

    Container(ms_aggregator, "MS-Aggregator (principal)", "Spring Boot 3.5 + Java 25 (hexagonal)", "Orquesta busqueda y pedidos. Decide las 3 reglas R1, R2, R3.")

    Container(ms_inventory, "MS-InventoryDirect (sincrono)", "Spring Boot 3.5 + Java 25", "Expone stock por (parte, proveedor). Slow-mode admin para forzar R1.")

    Container(ms_trends, "MS-TrendCollector (asincrono)", "Spring Boot 3.5 + Java 25", "Consume SearchFailedEvent y agrega tendencias por query.")

    ContainerDb(es, "Elasticsearch 8", "Search engine", "Catalogo de partes (full-text spanish).")
    ContainerDb(mysql_agg, "MySQL 8 — Aggregator", "RDBMS", "workshops + orders + outbox_events.")
    ContainerDb(mysql_inv, "MySQL 8 — InventoryDirect", "RDBMS", "inventory_items.")
    ContainerDb(pg_trends, "PostgreSQL 16 — Trends", "RDBMS", "failed_searches.")
    ContainerQueue(rabbit, "RabbitMQ 3.13", "Broker AMQP", "Exchange partfinder.search.events + DLX.")
}

System_Ext(prom, "Prometheus + Grafana", "Metricas y dashboards.")
System_Ext(jaeger, "Jaeger", "Trazabilidad distribuida (OTLP).")

' --- Trafico de usuario ---
Rel(mechanic, ui_gateway, "Usa SPA", "HTTPS")
Rel(supplier, ui_gateway, "Consulta tendencias", "HTTPS")

' --- Gateway -> MS ---
Rel(ui_gateway, ms_aggregator, "/api/aggregator/*", "HTTP")
Rel(ui_gateway, ms_inventory, "/api/inventory/* (admin)", "HTTP")
Rel(ui_gateway, ms_trends, "/api/trends/*", "HTTP")

' --- Aggregator -> stores + servicios ---
Rel(ms_aggregator, es, "Busqueda full-text del catalogo", "HTTP (Spring Data ES)")
Rel(ms_aggregator, mysql_agg, "Workshops + orders + outbox", "JDBC")
Rel(ms_aggregator, ms_inventory, "GET /inventory — timeout 800ms (R1)", "REST/Feign")
Rel(ms_aggregator, rabbit, "Publica SearchFailedEvent (R3) via outbox", "AMQP")

' --- InventoryDirect ---
Rel(ms_inventory, mysql_inv, "Lee/escribe stock", "JDBC")

' --- TrendCollector ---
Rel(rabbit, ms_trends, "Consume SearchFailedEvent (cola dedicada + DLQ)", "AMQP")
Rel(ms_trends, pg_trends, "Persiste tendencias", "JDBC")

' --- Observabilidad ---
Rel(ms_aggregator, prom, "/actuator/prometheus", "HTTP (scrape)")
Rel(ms_inventory, prom, "/actuator/prometheus", "HTTP (scrape)")
Rel(ms_trends, prom, "/actuator/prometheus", "HTTP (scrape)")
Rel(rabbit, prom, "Metricas RabbitMQ", "HTTP (scrape)")
Rel(ms_aggregator, jaeger, "Trazas OTLP", "OTLP/HTTP")
Rel(ms_inventory, jaeger, "Trazas OTLP", "OTLP/HTTP")
Rel(ms_trends, jaeger, "Trazas OTLP", "OTLP/HTTP")

@enduml
